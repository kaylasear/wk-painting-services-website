---

---

<section class="section section-soft" id="process">
  <div class="wrap">
    <div
      class="section-head fade-up"
      style="margin-left:auto;margin-right:auto;text-align:center;"
    >
      <p class="eyebrow" style="justify-content:center;">How it works</p>
      <h2>Four steps from estimate to finish.</h2>
    </div>
    <div class="process-icons">
      <div class="process-icon-card fade-up">
        <div class="process-icon-badge">
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.6"
          >
            <path d="M3 9l9-6 9 6"></path><path d="M5 9v11h14V9"></path><path
              d="M10 20v-6h4v6"></path>
          </svg>
        </div>
        <h3>Free in-home estimate</h3>
        <p>
          We walk the exterior with you, check siding and trim condition, and
          scope the work in writing.
        </p>
      </div>
      <div class="process-icon-card fade-up">
        <div class="process-icon-badge">
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.6"
          >
            <circle cx="12" cy="12" r="3.5"></circle>
            <path
              d="M12 2v3M12 19v3M4.2 4.2l2.1 2.1M17.7 17.7l2.1 2.1M2 12h3M19 12h3M4.2 19.8l2.1-2.1M17.7 6.3l2.1-2.1"
            ></path>
          </svg>
        </div>
        <h3>Color consultation</h3>
        <p>
          Pick from our exterior swatch library or bring your own — we'll check
          HOA guidelines if you have them.
        </p>
      </div>
      <div class="process-icon-card fade-up">
        <div class="process-icon-badge">
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.6"
          >
            <path d="M3 21l4-1 11-11-3-3L4 17l-1 4z"></path><path d="M14 6l3 3"
            ></path>
          </svg>
        </div>
        <h3>Wash, scrape &amp; protect</h3>
        <p>
          Power wash, scrape, caulk, and prime first; landscaping and walkways
          get covered before anything is sprayed.
        </p>
      </div>
      <div class="process-icon-card fade-up">
        <div class="process-icon-badge">
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.6"
          >
            <path d="M9 11l3 3L22 4"></path>
            <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"
            ></path>
          </svg>
        </div>
        <h3>Paint &amp; inspect</h3>
        <p>
          Two coats of weather-rated paint, applied by a two-person crew, with a
          final walkthrough before we call it done.
        </p>
      </div>
    </div>
  </div>
</section>
