---
import { Image } from "astro:assets";
import logo from "../../pictures/logo.png";
import { SITE } from "../config/site";
---

<section class="hero" id="top">
  <div class="wrap">
    <div class="hero-grid">
      <div>
        <p class="eyebrow">{SITE.tagline}</p>
        <h1>
          Customer Care
          <svg class="hero-underline" viewBox="0 0 420 18">
            <path d="M3 12C70 4 150 4 210 10C270 16 350 4 417 9"></path>
          </svg>
        </h1>
        <p class="lede">
          WK Painting Services, LLC provides exterior, interior, and cabinet
          painting across Pierce County and the surrounding areas — finished to
          hold up through Pacific Northwest weather and everyday wear. Clean job
          sites, real timelines, and a color consult included with every
          estimate.
        </p>
        <div class="hero-actions">
          <a href={SITE.estimateHref} class="btn btn-cta">Get a Free Estimate</a
          >
          <a href={SITE.phoneHref} class="btn btn-ghost">Call {SITE.phone}</a>
        </div>
        <div class="hero-trust">
          <div><strong>9 yrs</strong><span>In business</span></div>
          <div><strong>145+</strong><span>Homes painted</span></div>
          <div><strong>Family</strong><span>Owned &amp; operated</span></div>
        </div>
      </div>

      <div class="hero-art">
        <div class="hero-card">
          <h3>Freshly painted, every time</h3>
          <p>A clean, even finish on every interior project we take on.</p>
          <div class="room-illustration">
            <Image src={logo} alt={SITE.name} />
          </div>
        </div>
      </div>
    </div>

    <div class="trust-strip">
      <div class="wrap" style="padding:0;">
        <div class="trust-item">
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            ><path d="M12 2l8 4v6c0 5-3.5 8.5-8 10-4.5-1.5-8-5-8-10V6l8-4z"
            ></path></svg
          >
          Family owned &amp; operated
        </div>
        <div class="trust-item">
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            ><path d="M3 9l9-6 9 6"></path><path d="M5 9v11h14V9"></path></svg
          >
          145+ homes painted
        </div>
        <div class="trust-item">
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            ><path d="M9 11l3 3L22 4"></path><path
              d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"
            ></path></svg
          >
          Written estimates, no surprises
        </div>
        <div class="trust-item">
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            ><path
              d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"
            ></path></svg
          >
          Rated for PNW rain &amp; UV exposure
        </div>
        <div class="trust-item">
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            ><path d="M12 21s-7-6.5-7-11a7 7 0 0 1 14 0c0 4.5-7 11-7 11z"
            ></path><circle cx="12" cy="10" r="2.5"></circle></svg
          >
          Serving Pierce County &amp; beyond
        </div>
      </div>
    </div>
  </div>
</section>
