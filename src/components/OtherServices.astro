<section class="section other-svc">
  <div class="wrap">
    <div class="section-head fade-up">
      <p class="eyebrow">Add-on Services</p>
      <h2>Round out the project.</h2>
      <p>Common add-ons homeowners pair with an exterior repaint.</p>
    </div>
    <div class="other-svc-grid">
      {[
        "Power Washing",
        "Deck & Fence Staining",
        "Siding Repair",
        "Stucco Painting",
        "Trim & Fascia",
        "Garage Door Painting",
        "Gutter & Downspout Painting",
        "Wood Rot Repair",
      ].map(name => (
        <a href="#estimate" class="other-svc-item fade-up">
          <span>{name}</span>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      ))}
    </div>
  </div>
</section>
