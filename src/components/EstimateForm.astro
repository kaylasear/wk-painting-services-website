---
import { PROJECT_TYPES, TIMELINE_OPTIONS } from "../config/constants";
---

<section class="section estimate">
  <div class="wrap">
    <div class="est-grid">
      <div>
        <p class="eyebrow">Get Started</p>
        <h2>Request your free estimate.</h2>
        <p class="lede">
          Tell us a bit about your project. We'll call or email within one
          business day to schedule a walkthrough.
        </p>
        <ul class="est-points">
          <li>
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              ><path d="M9 11l3 3L22 4"></path><path
                d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"
              ></path></svg
            >
            No-pressure, written estimate
          </li>
          <li>
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              ><circle cx="12" cy="12" r="10"></circle><path d="M12 6v6l4 2"
              ></path></svg
            >
            Usually scheduled within 2–3 days
          </li>
          <li>
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              ><path
                d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78L12 21.23l8.84-8.84a5.5 5.5 0 0 0 0-7.78z"
              ></path></svg
            >
            Color consult included, always
          </li>
        </ul>
      </div>

      <div class="est-form">
        <form id="estimateForm">
          <input
            type="hidden"
            name="access_key"
            value={import.meta.env.PUBLIC_WEB3FORMS_KEY}
          />
          <input type="hidden" name="subject" value="New estimate request" />
          <input type="hidden" name="from_name" value="WK Painting Services" />
          <input
            type="checkbox"
            name="botcheck"
            class="hp-field"
            tabindex="-1"
            autocomplete="off"
          />
          <div class="est-row">
            <div class="field">
              <label for="name">Full name</label>
              <input id="name" name="name" type="text" required />
            </div>
            <div class="field">
              <label for="phone">Phone</label>
              <input id="phone" name="phone" type="tel" required />
            </div>
          </div>
          <div class="field">
            <label for="email">Email</label>
            <input id="email" name="email" type="email" required />
          </div>
          <div class="field">
            <label for="address">Property address</label>
            <input
              id="address"
              name="address"
              type="text"
              placeholder="Street, city"
              required
            />
          </div>
          <div class="est-row">
            <div class="field">
              <label for="project">Project Type</label>
              <select id="project" name="project">
                {PROJECT_TYPES.map((type) => <option>{type}</option>)}
              </select>
            </div>
            <div class="field">
              <label for="timeline">Timeline</label>
              <select id="timeline" name="timeline">
                {TIMELINE_OPTIONS.map((option) => <option>{option}</option>)}
              </select>
            </div>
          </div>
          <div class="field">
            <label for="details">Project details</label>
            <textarea
              id="details"
              name="details"
              placeholder="Rooms, square footage, anything we should know"
            ></textarea>
          </div>
          <button type="submit" class="btn btn-cta"
            >Request My Free Estimate</button
          >
          <p class="form-note">
            By submitting, you agree to be contacted about your estimate. No
            spam, ever.
          </p>
          <p id="formError" class="form-error">
            Something went wrong sending your request. Please try again, or call
            us directly.
          </p>
        </form>
        <div id="formSuccess">
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.6"
          >
            <circle cx="12" cy="12" r="10"></circle><path d="M8 12l3 3 5-6"
            ></path>
          </svg>
          <h3>Request received</h3>
          <p>
            Thanks — a member of the WK Painting Services, LLC team will reach
            out to schedule your walkthrough.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById("estimateForm") as HTMLFormElement;
  const success = document.getElementById("formSuccess") as HTMLElement;
  const error = document.getElementById("formError") as HTMLElement;
  const submitBtn = form?.querySelector(
    'button[type="submit"]',
  ) as HTMLButtonElement;

  if (form && success && error && submitBtn) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      error.style.display = "none";
      submitBtn.disabled = true;
      submitBtn.textContent = "Sending…";

      try {
        const response = await fetch("https://api.web3forms.com/submit", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            Accept: "application/json",
          },
          body: JSON.stringify(Object.fromEntries(new FormData(form))),
        });
        const result = await response.json();

        if (result.success) {
          form.style.display = "none";
          success.style.display = "block";
        } else {
          throw new Error(result.message || "Submission failed");
        }
      } catch {
        error.style.display = "block";
        submitBtn.disabled = false;
        submitBtn.textContent = "Request My Free Estimate";
      }
    });
  }
</script>
