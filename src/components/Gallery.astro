---
---
<section class="section section-soft" id="gallery">
  <div class="wrap">
    <div class="section-head fade-up">
      <p class="eyebrow">Color Library</p>
      <h2>Palettes from recent projects.</h2>
      <p>A few of the exterior combinations our color consultants have mixed for South Sound homes this season.</p>
    </div>
    <div class="gal-grid">
      <div class="gal-card fade-up">
        <svg class="gal-art" viewBox="0 0 400 200" preserveAspectRatio="xMidYMid slice">
          <rect width="400" height="200" fill="#BFD3E0"/>
          <rect x="0" y="150" width="400" height="50" fill="#8C9A8E"/>
          <polygon points="70,150 200,70 330,150" fill="#3E5C82"/>
          <rect x="100" y="100" width="200" height="50" fill="#3E5C82"/>
          <rect x="185" y="115" width="30" height="35" fill="#2A2A28"/>
        </svg>
        <div class="gal-body">
          <h3>Full Exterior — Proctor District</h3>
          <p>Slate blue siding, charcoal door, soft white trim.</p>
        </div>
      </div>
      <div class="gal-card fade-up">
        <svg class="gal-art" viewBox="0 0 400 200" preserveAspectRatio="xMidYMid slice">
          <rect width="400" height="200" fill="#E7E2D6"/>
          <rect x="0" y="0" width="400" height="60" fill="#C9C2B2"/>
          <rect x="30" y="70" width="150" height="110" fill="#C1602E"/>
          <rect x="200" y="70" width="170" height="110" fill="#2A2A28"/>
        </svg>
        <div class="gal-body">
          <h3>Trim &amp; Shutters — North Tacoma</h3>
          <p>Clay front door, charcoal shutters, original siding kept.</p>
        </div>
      </div>
      <div class="gal-card fade-up">
        <svg class="gal-art" viewBox="0 0 400 200" preserveAspectRatio="xMidYMid slice">
          <rect width="400" height="200" fill="#EFE7DA"/>
          <rect x="0" y="0" width="400" height="50" fill="#9CA8A0"/>
          <rect x="0" y="130" width="400" height="70" fill="#6E4B3A"/>
          <rect x="40" y="50" width="320" height="80" fill="#D8CDBC"/>
          <rect x="160" y="50" width="20" height="150" fill="#9CA8A0"/>
        </svg>
        <div class="gal-body">
          <h3>Deck Stain &amp; Railing — Gig Harbor</h3>
          <p>Warm walnut deck stain with weathered-gray railings.</p>
        </div>
      </div>
    </div>
  </div>
</section>
