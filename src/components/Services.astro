---
import { SITE } from "../config/site";

const services = [
  {
    title: "Exterior Painting",
    desc: "Siding, trim, doors, fascia, and decks — fully prepped, primed, and finished with paint rated for South Sound weather.",
    icon: `<path d="M3 9l9-6 9 6"/><path d="M5 9v11h14V9"/><path d="M10 20v-6h4v6"/>`,
  },
  {
    title: "Interior Painting",
    desc: "Walls, trim, ceilings, and cabinetry, prepped and finished room by room.",
    icon: `<path d="M3 21l4-1 11-11-3-3L4 17l-1 4z"/><path d="M14 6l3 3"/>`,
  },
  {
    title: "Cabinet Painting",
    desc: "Spray-finished cabinets that look replaced, not repainted.",
    icon: `<rect x="4" y="3" width="16" height="18" rx="1"/><path d="M4 11h16"/><circle cx="8" cy="7" r="0.6" fill="currentColor"/><circle cx="8" cy="16" r="0.6" fill="currentColor"/>`,
  },
];
---

<section class="section" id="services">
  <div class="wrap">
    <div class="section-head fade-up">
      <p class="eyebrow">Services</p>
      <h2>What we do.</h2>
      <p>
        Three services, one crew, the same careful prep and 2-year warranty on
        every job.
      </p>
    </div>
    <div class="svc-grid svc-grid--3col">
      {
        services.map((s) => (
          <div class="svc-card fade-up">
            <svg
              class="svc-icon"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.6"
              set:html={s.icon}
            />
            <h3>{s.title}</h3>
            <p>{s.desc}</p>
          </div>
        ))
      }
    </div>
    <div style="margin-top:36px;text-align:center;">
      <a href={SITE.estimateHref} class="btn btn-cta">Get a Free Estimate</a>
    </div>
  </div>
</section>
