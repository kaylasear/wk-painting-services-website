---
import LogoMark from "./LogoMark.astro";
import { SITE } from "../config/site";
import { withBase } from "../utils/url";
---

<footer>
  <div class="wrap">
    <div class="foot-grid">
      <div>
        <div class="foot-logo">
          <LogoMark />
        </div>
        <p class="tag">
          Interior, exterior, and cabinet painting for Pierce County homes.
          Family owned and locally operated since 2017.
        </p>
      </div>
      <div class="foot-col">
        <h4>Services</h4>
        <ul>
          <li>
            <a href={withBase("/residential-painting")}>Exterior Painting</a>
          </li>
          <li><a href={withBase("/#services")}>Interior Painting</a></li>
          <li><a href={withBase("/#services")}>Cabinet Painting</a></li>
        </ul>
      </div>
      <div class="foot-col">
        <h4>Company</h4>
        <ul>
          <li><a href={withBase("/about")}>About Us</a></li>
          <li><a href={withBase("/reviews")}>Reviews</a></li>
          <li><a href={withBase("/#process")}>Our Process</a></li>
          <li><a href={withBase("/#gallery")}>Color Library</a></li>
        </ul>
      </div>
      <div class="foot-col">
        <h4>Contact</h4>
        <ul>
          <li><a href={SITE.phoneHref}>{SITE.phone}</a></li>
          <li><a href={`mailto:${SITE.email}`}>{SITE.email}</a></li>
          <li>{SITE.hours}</li>
        </ul>
      </div>
    </div>
    <div class="foot-bottom">
      <span>&copy; 2026 {SITE.name}. All rights reserved.</span>
    </div>
  </div>
</footer>
