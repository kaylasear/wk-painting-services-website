---
import Layout from "../layouts/Layout.astro";
import TopNav from "../components/TopNav.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import MobileCTA from "../components/MobileCTA.astro";
import PageHero from "../components/PageHero.astro";
import PageCTA from "../components/PageCTA.astro";
import { SITE } from "../config/site";

const services = [
  {
    title: "Exterior Siding",
    desc: "Full prep, prime, and two coats on any siding type — wood, Hardie board, vinyl, stucco, or T1-11. Rated for Pacific Northwest weather.",
    icon: `<path d="M3 9l9-6 9 6"/><path d="M5 9v11h14V9"/><path d="M10 20v-6h4v6"/>`,
  },
  {
    title: "Trim & Fascia",
    desc: "Clean lines on every board, window casing, and soffit. We mask meticulously so trim color never bleeds onto siding.",
    icon: `<rect x="2" y="3" width="20" height="4" rx="1"/><rect x="2" y="10" width="20" height="4" rx="1"/><rect x="2" y="17" width="20" height="4" rx="1"/>`,
  },
  {
    title: "Gutters",
    desc: "Repainting gutters prevents rust and keeps them blending seamlessly with your home's color scheme.",
    icon: `<path d="M3 6h18"/><path d="M6 6v4a3 3 0 0 0 3 3h6a3 3 0 0 0 3-3V6"/><path d="M12 13v7"/><path d="M9 17l3 3 3-3"/>`,
  },
  {
    title: "Shutters",
    desc: "Whether decorative or functional, shutters get careful prep and coating to hold up against sun fade and moisture over time.",
    icon: `<rect x="3" y="3" width="7" height="18" rx="1"/><rect x="14" y="3" width="7" height="18" rx="1"/>`,
  },
  {
    title: "Front Doors & Entries",
    desc: "A fresh door makes the whole house. We hand-paint for a factory-smooth finish and add weather-resistant topcoat to stand up to daily use.",
    icon: `<rect x="3" y="2" width="18" height="20" rx="1"/><circle cx="16" cy="12" r="1.5" fill="currentColor"/>`,
  },
  {
    title: "Decks & Fences",
    desc: "Solid stains or semi-transparent finishes that protect wood grain while adding lasting color. Includes light sanding and cleaning.",
    icon: `<path d="M3 21h18"/><path d="M5 17V8"/><path d="M9 17V8"/><path d="M13 17V8"/><path d="M17 17V8"/><path d="M3 8h18"/>`,
  },
  {
    title: "Garage Doors",
    desc: "We restore faded or peeling garage doors to match the new exterior. Proper adhesion prep so paint doesn't chip when the door cycles.",
    icon: `<rect x="2" y="4" width="20" height="16" rx="2"/><path d="M2 10h20M2 14h20"/>`,
  },
  {
    title: "Power Washing",
    desc: "Every job starts with a thorough wash to remove mildew, dirt, and chalking — so new paint bonds properly and lasts longer.",
    icon: `<path d="M7 16.5c0 1.38 2.24 2.5 5 2.5s5-1.12 5-2.5"/><path d="M12 7v5"/><path d="M8 9l4-4 4 4"/>`,
  },
];

const included = [
  "Full power wash before any paint is applied",
  "Scraping and sanding of loose or peeling areas",
  "Caulking gaps at trim, windows, and seams",
  "Spot-prime on bare wood and repaired areas",
  "Two finish coats of weather-rated exterior paint",
  "Daily cleanup — no tools, no tape left behind",
  "Final walkthrough with you before we close out",
];
---

<Layout
  title={`Exterior Painting | ${SITE.name}`}
  description="Professional exterior painting in Pierce County. Siding, trim, gutters, shutters, doors, and more. Free estimates."
>
  <TopNav currentPage="residential" />
  <Header />

  <PageHero
    eyebrow="Exterior Painting"
    heading="Your home's exterior,<br />done right."
    body="From full re-sides to a single front door — WK Painting Services handles every exterior job with the same careful prep and the same experienced crew."
  >
    <div class="hero-actions">
      <a href={SITE.estimateHref} class="btn btn-cta">Get a Free Estimate</a>
      <a href={SITE.phoneHref} class="btn btn-ghost">Call {SITE.phone}</a>
    </div>
  </PageHero>

  <section class="section">
    <div class="wrap">
      <div class="section-head fade-up">
        <p class="eyebrow">What we paint</p>
        <h2>Every surface, handled.</h2>
        <p>
          We scope each project in detail up front, so nothing gets missed once
          work begins.
        </p>
      </div>
      <div class="svc-grid svc-grid--3col">
        {
          services.map((s) => (
            <div class="svc-card fade-up">
              <svg
                class="svc-icon"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.6"
                set:html={s.icon}
              />
              <h3>{s.title}</h3>
              <p>{s.desc}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section section-soft">
    <div class="wrap">
      <div class="content-split">
        <div class="fade-up">
          <p class="eyebrow">What's included</p>
          <h2>Every job includes these — not as add-ons.</h2>
          <ul class="checklist">
            {
              included.map((item) => (
                <li>
                  <svg
                    class="check-icon"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <path d="M9 11l3 3L22 4" />
                    <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11" />
                  </svg>
                  {item}
                </li>
              ))
            }
          </ul>
        </div>
        <div class="fade-up">
          <div class="pricing-card">
            <p class="pricing-card-eyebrow">Free Estimate</p>
            <h3>Get a written quote for your project</h3>
            <p class="pricing-note">
              Every estimate is free and provided in writing before any work
              begins — no obligation, no pressure.
            </p>
            <a href={SITE.estimateHref} class="btn btn-cta"
              >Request a Free Estimate</a
            >
          </div>
        </div>
      </div>
    </div>
  </section>

  <PageCTA
    variant="cta"
    heading="Ready to refresh your exterior?"
    body="We schedule estimates within 2–3 days. No obligation, no pressure, and a color consult is always included."
  >
    <a href={SITE.estimateHref} class="btn btn-dark">Get My Free Estimate</a>
  </PageCTA>

  <Footer />
  <MobileCTA />
</Layout>
