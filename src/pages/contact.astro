---
import Layout from "../layouts/Layout.astro";
import TopNav from "../components/TopNav.astro";
import Header from "../components/Header.astro";
import EstimateForm from "../components/EstimateForm.astro";
import Footer from "../components/Footer.astro";
import MobileCTA from "../components/MobileCTA.astro";
import { SITE } from "../config/site";
---

<Layout
  title={`Contact Us | ${SITE.name}`}
  description={`Request a free painting estimate from ${SITE.name}. We'll call or email to schedule a walkthrough.`}
>
  <TopNav currentPage="contact" />
  <Header />

  <EstimateForm />

  <Footer />
  <MobileCTA />
</Layout>
