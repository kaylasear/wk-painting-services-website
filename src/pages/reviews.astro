---
import Layout from "../layouts/Layout.astro";
import TopNav from "../components/TopNav.astro";
import Header from "../components/Header.astro";
import Reviews from "../components/Reviews.astro";
import Footer from "../components/Footer.astro";
import MobileCTA from "../components/MobileCTA.astro";
import PageHero from "../components/PageHero.astro";
import PageCTA from "../components/PageCTA.astro";
import { SITE } from "../config/site";
---

<Layout
  title={`Customer Reviews | ${SITE.name}`}
  description="See what Pierce County homeowners say about WK Painting Services."
>
  <TopNav currentPage="reviews" />
  <Header />

  <PageHero
    eyebrow="Customer Reviews"
    heading="What our customers<br />are saying."
    body="Here's a sample of what our customers in Pierce County have to say after we wrap up a project."
  />

  <section class="section">
    <div class="wrap">
      <Reviews />
    </div>
  </section>

  <PageCTA
    variant="dark"
    eyebrow="Get Started"
    heading="Ready to be our next happy customer?"
    body="Free estimate, color consult included, no pressure. We'll have a quote to you within one business day."
  >
    <a href={SITE.estimateHref} class="btn btn-cta">Request a Free Estimate</a>
  </PageCTA>

  <Footer />
  <MobileCTA />
</Layout>
