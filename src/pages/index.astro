---
import Layout from '../layouts/Layout.astro';
import TopNav from '../components/TopNav.astro';
import PromoBar from '../components/PromoBar.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Warranty from '../components/Warranty.astro';
import Services from '../components/Services.astro';
import OtherServices from '../components/OtherServices.astro';
import Process from '../components/Process.astro';
import Stats from '../components/Stats.astro';
import Gallery from '../components/Gallery.astro';
import Reviews from '../components/Reviews.astro';
import EstimateForm from '../components/EstimateForm.astro';
import Footer from '../components/Footer.astro';
import MobileCTA from '../components/MobileCTA.astro';
---
<Layout>
  <TopNav currentPage="" />
  <PromoBar />
  <Header />
  <Hero />
  <Warranty />
  <Services />
  <OtherServices />
  <Process />
  <Stats />
  <Gallery />
  <section class="section" id="reviews">
    <div class="wrap">
      <div class="section-head fade-up">
        <p class="eyebrow">Reviews</p>
        <h2>What the South Sound is saying.</h2>
      </div>
      <Reviews limit={3} />
      <div style="margin-top:36px;text-align:center;">
        <a href="/reviews" class="btn btn-ghost">See all reviews</a>
      </div>
    </div>
  </section>
  <EstimateForm />
  <Footer />
  <MobileCTA />
</Layout>
