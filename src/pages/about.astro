---
import Layout from "../layouts/Layout.astro";
import TopNav from "../components/TopNav.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import MobileCTA from "../components/MobileCTA.astro";
import PageHero from "../components/PageHero.astro";
import PageCTA from "../components/PageCTA.astro";
import { SITE } from "../config/site";

const stats = [
  { value: "2017", label: "Year founded" },
  { value: "145+", label: "Projects completed" },
  { value: "3", label: "Services offered" },
  { value: "Family", label: "Owned & operated" },
];

const values = [
  {
    title: "Prep is everything",
    desc: "The reason paint fails isn't the paint — it's skipped prep. We power wash, scrape, caulk, and prime before a single finish coat goes on.",
  },
  {
    title: "No subcontractors",
    desc: "The same crew that gives your estimate does the work. No hand-offs, no surprises, and someone accountable from day one to final walkthrough.",
  },
  {
    title: "Clean job sites, daily",
    desc: "We cover landscaping before spraying and clean up every evening. You shouldn't come home to a mess on your own property.",
  },
  {
    title: "Honest estimates",
    desc: "We scope everything in writing before work starts. The price on your estimate is the price on your invoice — we don't find surprises after the fact.",
  },
];

const serviceArea = ["Tacoma", "Puyallup", "Bonney Lake", "Graham", "Spanaway"];
---

<Layout
  title={`About Us | ${SITE.name}`}
  description={`${SITE.name} is a locally owned painting company serving Pierce County since 2017. Interior, exterior, and cabinet painting with a focus on precision and honest communication.`}
>
  <TopNav currentPage="about" />
  <Header />

  <PageHero
    eyebrow="About Us"
    heading="Locally owned since 2017."
    body="WK Painting Services is a family-owned painting company built on precision and lasting quality — not quick, cut-corner work. We're a small crew, not a franchise, and that's intentional."
  />

  <section class="section">
    <div class="wrap">
      <div class="content-split">
        <div class="fade-up">
          <p class="eyebrow">Our story</p>
          <h2>Started in Pierce County, still here.</h2>
          <p class="story-body">
            WK Painting Services is owned and operated by Wayne Khim, serving
            Pierce County and the surrounding areas — including Tacoma,
            Puyallup, Bonney Lake, Graham, and Spanaway. We specialize in
            interior and exterior painting as well as cabinet painting and
            refinishing, always with an emphasis on precision and lasting
            quality over quick, cut-corner work.
          </p>
          <p class="story-body">
            As a family business, we treat every job like it's our own home, and
            we stand behind what we deliver. What sets us apart is the attention
            to detail, backed by honest communication and a free quote.
          </p>
          <p class="story-body">
            Since 2017, we've painted more than 145 homes across Pierce County —
            and we're just getting started.
          </p>
        </div>
        <div class="fade-up">
          <div class="stat-mini-grid">
            {
              stats.map((s) => (
                <div class="stat-mini">
                  <strong>{s.value}</strong>
                  <span>{s.label}</span>
                </div>
              ))
            }
          </div>
          <div class="license-badge">
            <div class="license-badge-top">
              <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="#FFC629"
                stroke-width="2"
              >
                <path d="M12 2l8 4v6c0 5-3.5 8.5-8 10-4.5-1.5-8-5-8-10V6l8-4z"
                ></path>
                <path d="M9 12l2 2 4-4"></path>
              </svg>
              <strong>Licensed &amp; Insured</strong>
            </div>
            <p>
              WK Painting Services, LLC is licensed and insured, and takes on
              residential projects only.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-soft">
    <div class="wrap">
      <div
        class="section-head fade-up"
        style="margin-left:auto;margin-right:auto;text-align:center;"
      >
        <p class="eyebrow" style="justify-content:center;">How we work</p>
        <h2>The things we won't cut corners on.</h2>
      </div>
      <div class="svc-grid" style="grid-template-columns:repeat(2,1fr);">
        {
          values.map((v) => (
            <div class="svc-card fade-up">
              <h3>{v.title}</h3>
              <p>{v.desc}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <div class="section-head fade-up">
        <p class="eyebrow">Service area</p>
        <h2>We serve Pierce County.</h2>
        <p>Based in Tacoma — we travel to wherever your home is in the area.</p>
      </div>
      <div class="area-grid">
        {serviceArea.map((city) => <div class="area-chip">{city}</div>)}
      </div>
    </div>
  </section>

  <PageCTA
    variant="cta"
    heading="Let's talk about your project."
    body="Free estimate, color consult included. We'll walk your project with you and give you a written quote with no obligation."
  >
    <a href={SITE.estimateHref} class="btn btn-dark">Get a Free Estimate</a>
    <a href={SITE.phoneHref} class="btn btn-ghost">Call {SITE.phone}</a>
  </PageCTA>

  <Footer />
  <MobileCTA />
</Layout>

<style>
  .story-body {
    margin-top: 16px;
    font-size: 16px;
    color: var(--ink-soft);
    line-height: 1.7;
  }

  @media (max-width: 760px) {
    .svc-grid[style] {
      grid-template-columns: 1fr !important;
    }
  }
</style>
